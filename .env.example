# =============================================================================
# SignBank Environment Configuration
# Copy this file to .env and fill in your values: cp .env.example .env
# =============================================================================

# --- Application ---
BASE_URL=localhost
PORT=443

# --- Database ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=signbank
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/signbank
DATABASE_URL_DOCKER=postgresql://postgres:postgres@postgres:5432/signbank

# --- Admin account (created on first startup via seed) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# --- Typesense search engine ---
TYPESENSE_API_KEY=your-typesense-api-key-here
TYPESENSE_HOST=typesense
TYPESENSE_PORT=8108

# --- File server ---
FILE_SERVER_PATH=/production/FileServer
DUFS_URL=http://dufs:5000

# --- JWT authentication ---
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRATION=24h

# --- SSL (optional, for production) ---
# SSL_CERTIFICATE_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
# SSL_PRIVATE_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
